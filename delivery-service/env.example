# Delivery Service Environment Configuration

# Server Configuration
PORT=5004
SERVICE_NAME=delivery-service

# Database Configuration
DATABASE_URL=mongodb://admin:admin123@localhost:27017/delivery_service?authSource=admin

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=delivery-service
KAFKA_GROUP_ID=delivery-service-group

# Application Configuration
NODE_ENV=development
KAFKAJS_NO_PARTITIONER_WARNING=1

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175

# OSRM Configuration (Open Source Routing Machine)
# Run ./osrm-setup.sh first, then docker compose up osrm
OSRM_URL=http://localhost:5050

# Driver Selection Configuration
DRIVER_SEARCH_RADIUS_KM=5          # Initial search radius in km
DRIVER_MAX_SEARCH_RADIUS_KM=25     # Max radius before giving up geo-search
DRIVER_WEIGHT_TIME=0.7              # Weight for proximity (0-1)
DRIVER_WEIGHT_RATING=0.3            # Weight for driver rating (0-1)
DRIVER_LOCATION_STALE_MINUTES=15    # Ignore driver locations older than this